<?xml version="1.0" encoding="UTF-8"?>
<javaee:handler-chains xmlns="http://java.sun.com/xml/ns/jax-ws/ri/runtime"
	xmlns:javaee="http://java.sun.com/xml/ns/javaee">
	<javaee:handler-chain>
		<javaee:handler>
			<!-- Validate Checksum  (Payload & Fields - configuration driven).  -->
			<javaee:handler-name>IntegrityValidator</javaee:handler-name>
			<javaee:handler-class>com.icicibank.ws.configrity.intimation.handlers.IntegrityValidator</javaee:handler-class>
		</javaee:handler>
		<javaee:handler>
			<!-- Authenticate API User (Basic & Custom - configuration driven).  -->
			<javaee:handler-name>UserAuthentication</javaee:handler-name>
			<javaee:handler-class>com.icicibank.ws.configrity.intimation.handlers.UserAuthentication</javaee:handler-class>
		</javaee:handler>
		<javaee:handler>
			<!-- Decrypt request / Encrypt response (configuration driven).  -->
			<javaee:handler-name>PayloadConfidentialityValidator</javaee:handler-name>
			<javaee:handler-class>com.icicibank.ws.configrity.intimation.handlers.CompactPayloadsConfidentialityValidator</javaee:handler-class>
		</javaee:handler>
		<javaee:handler>
			<!-- Audit request / response messages.  -->
			<javaee:handler-name>MessageAuditor</javaee:handler-name>
			<javaee:handler-class>com.icicibank.ws.configrity.intimation.handlers.MessageAuditor</javaee:handler-class>
		</javaee:handler>
	</javaee:handler-chain>	
</javaee:handler-chains>
