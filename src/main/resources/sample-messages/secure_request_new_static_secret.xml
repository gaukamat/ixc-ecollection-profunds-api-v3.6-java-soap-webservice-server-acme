<?xml version="1.0" encoding="UTF-8"?>
<tns:secure_request
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:tns="http://www.icicibank.com/api/acme/configrity"
	xsi:schemaLocation="http://www.icicibank.com/api/acme/configrity ../xsd/intimation-configrity.xsd">
	<tns:encoding>base64</tns:encoding>
	<tns:key_sharing>static</tns:key_sharing>
	<tns:data_encryption_cipher_algo_name>DES</tns:data_encryption_cipher_algo_name>
	<tns:data_encryption_cipher_mode>OFB</tns:data_encryption_cipher_mode>
	<tns:data_encryption_cipher_padding>PKCS5Padding</tns:data_encryption_cipher_padding>
	<tns:data_encryption_cipher_iv></tns:data_encryption_cipher_iv>
	<tns:secret_key_id>acme-des-128</tns:secret_key_id>
	<tns:clear_payload></tns:clear_payload>
	<tns:encrypted_payload></tns:encrypted_payload>
</tns:secure_request>
